# Anthropic API key — enables real LLM cognition for agents via AgentBrain
# Without this key the simulation falls back to template-based generation gracefully
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# Server configuration
PORT=3001
HOST=0.0.0.0
TICK_INTERVAL_MS=2000
CORS_ORIGIN=http://localhost:5173

# Web3 / DID identity (optional)
BASE_RPC_URL=
DID_SIGNER_PRIVATE_KEY=

# Privy wallet provisioning (optional)
PRIVY_APP_ID=
PRIVY_APP_SECRET=
